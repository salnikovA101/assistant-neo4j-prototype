# === LLM Profiles ===

# Gemini (direct API)
LLM__PROFILES__GEMINI__API_KEY=your-gemini-api-key
LLM__PROFILES__GEMINI__BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenRouter (or any OpenAI-compatible provider)
LLM__PROFILES__OTHER__API_KEY=your-openrouter-api-key
LLM__PROFILES__OTHER__BASE_URL=https://openrouter.ai/api/v1

# === TTS (Cloud) ===
TTS__CLOUD__API_KEY=your-tts-api-key
TTS__CLOUD__BASE_URL=https://openrouter.ai/api/v1

# === Neo4j ===
NEO4J__URI=bolt://localhost:7687
NEO4J__USER=neo4j
NEO4J__PASSWORD=your-neo4j-password
